---
import HeroCard from './HeroCard.astro';
---

<section class="ecosystem hero__sticky-wrapper" id="ecosystem">
	<div class="hero__sticky-content">
		<!-- Фоновый оранжевый градиентный слой -->
		<div class="hero__sticky-bg-orange"></div>
		<!-- Фоновый серый градиентный слой -->
		<div class="hero__sticky-bg-gray"></div>
		<div class="container hero__ecosystem-container">
			<div class="hero__ecosystem">
				<div class="hero__section-label hero__section-label--dark">
					<span class="hero__number">02</span>
					<div class="hero__label-block">
						<span class="hero__label" typewriter="true" typewriter-delay="150">
							<span class="split-lines">
								<span class="split-words">
									<span class="split-chars">Э</span><span class="split-chars">к</span><span class="split-chars">о</span><span class="split-chars">с</span><span class="split-chars">и</span><span class="split-chars">с</span><span class="split-chars">т</span><span class="split-chars">е</span><span class="split-chars">м</span><span class="split-chars">а</span>
								</span>
							</span>
						</span>
						<span class="hero__line hero__line--dark"></span>
					</div>
				</div>

				<div class="hero__stats">
					<div class="hero__stat" id="stat-divisions">
						<span class="hero__stat-value hero__stat-value--filled">5</span>
						<span class="hero__stat-caption hero__stat-caption--filled">подразделений</span>
					</div>
					<div class="hero__stat" id="stat-services">
						<span class="hero__stat-value hero__stat-value--outlined">12</span>
						<span class="hero__stat-caption hero__stat-caption--outlined">сервисов</span>
					</div>
					<div class="hero__stat" id="stat-actions">
						<span class="hero__stat-value hero__stat-value--outlined">70</span>
						<span class="hero__stat-caption hero__stat-caption--outlined">услуг</span>
					</div>
				</div>
			</div>
		</div>

		<div class="hero__sticky-dynamic">
			<div class="hero__cards">
				<div class="hero__cards-inner">
					<HeroCard
						en="Expert"
						ru="Управление"
						items={`Reserch /PMO\n/Due diligence`}
						logo={import.meta.env.BASE_URL + 'Media/logo1.png'}
						theme="expert"
					/>
					<HeroCard
						en="Communications"
						ru="Продвижение"
						items={`PR /Marketing\n/Buying`}
						logo={import.meta.env.BASE_URL + 'Media/logo2.png'}
						theme="communications"
					/>
					<HeroCard
						en="Media"
						ru="Креатив"
						items={`Media Production\n/Design /Web & App`}
						logo={import.meta.env.BASE_URL + 'Media/logo3.png'}
						theme="media"
					/>
					<HeroCard
						en="Events"
						ru="События"
						items={`Technical solutions\n/Event`}
						logo={import.meta.env.BASE_URL + 'Media/logo4.png'}
						theme="events"
					/>
					<HeroCard
						en="Academy"
						ru="Обучение"
						items={`Educational\nprojects`}
						logo={import.meta.env.BASE_URL + 'Media/logo1.png'}
						theme="academy"
					/>
				</div>
			</div>

			<div class="hero__services-wrapper">
				<div class="container services__inner">
					<div class="services__left">
						<h2 class="services__title">
							Подразделения предоставляют сервисы в рамках своей экспертизы
						</h2>
						<p class="services__desc">
							Единое пространство для управления проектами любой сложности
						</p>
					</div>

					<div class="services__right">
						<div class="services__table">
							<!-- Заполняется динамически из JS -->
						</div>
					</div>
				</div>
			</div>

			<div class="hero__actions-wrapper">
				<div class="container actions__inner">
					<div class="actions__header">
						<h2 class="actions__title">
							Каждый сервис предлагает<br />набор профильных услуг
						</h2>
						<p class="actions__desc">
							<svg class="actions__desc-icon" width="17" height="17" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M3.14185 0V1.75466H13.9546L0 15.7093L1.25858 17L15.2453 3.00865V13.7892H17V0H3.14185Z" fill="currentColor"/>
							</svg>Их сочетание позволяет реализовывать точные и эффективные<br />решения, объединяя экспертизу, креативность и управляемость
						</p>
					</div>
				</div>

				<div class="actions__content">
					<div class="actions__rows" data-base-url={import.meta.env.BASE_URL}>
						<div class="actions__row-pills actions__row-pills--1"></div>
						<div class="actions__row-pills actions__row-pills--2"></div>
					</div>
					<div class="container">
						<button class="actions__btn">
							<svg class="actions__btn-icon" width="10" height="10" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
								<path d="M3.14185 0V1.75466H13.9546L0 15.7093L1.25858 17L15.2453 3.00865V13.7892H17V0H3.14185Z" fill="currentColor"/>
							</svg>
							<span class="actions__btn-text">Выбрать сервис</span>
						</button>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
.ecosystem {
	position: relative;
	background-color: #ffffff;
	z-index: 1;
}

.hero__section-label {
	display: flex;
	align-items: flex-start;
	gap: 80px;
	color: var(--color-white);
}

.hero__section-label--dark {
	color: #000000;
}

.hero__number {
	font-size: 12px;
	font-weight: 400;
	line-height: 1;
	opacity: 0.8;
	min-width: 30px;
	padding-top: 4px;
}

.hero__label-block {
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.hero__label {
	font-size: 15px;
	font-weight: 400;
	line-height: 1;
}

.hero__line {
	display: block;
	width: 50px;
	height: 1px;
	background: var(--color-accent);
}

.hero__line--dark {
	background: #000000;
}

.hero__sticky-wrapper {
	position: relative;
}

.hero__sticky-bg-orange {
	position: absolute;
	top: 150px;
	left: 0;
	right: 0;
	bottom: 0;
	width: 100%;
	background: linear-gradient(180deg, #adb0c1 50%, #ffffff 90%, #ffffff 100%);
	z-index: 1;
	pointer-events: none;
	transform: translateY(100%);
	border-radius: 40px 40px 0 0;
}

.hero__sticky-bg-gray {
	position: absolute;
	top: 200px;
	left: 0;
	right: 0;
	bottom: 0;
	width: 100%;
	background: linear-gradient(180deg, #ff5000 50%, #ffffff 90%, #ffffff 100%);
	z-index: 1;
	pointer-events: none;
	transform: translateY(100%);
	border-radius: 40px 40px 0 0;
}

@media (min-width: 769px) {
	.hero__sticky-wrapper {
		height: 500vh; /* Увеличим высоту для трех фаз */
	}
	
	.hero__sticky-content {
		position: sticky;
		top: 0;
		height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: normal;
		overflow: hidden;
		padding: 60px 0 60px;
		z-index: 2;
	}
	
	.hero__sticky-bg-orange {
		z-index: 3; /* Выезжает поверх карточек */
	}

	.hero__sticky-bg-gray {
		z-index: 5; /* Выезжает поверх оранжевого фона и сервисов */
	}
	
	.hero__ecosystem {
		margin-top: 0;
		position: relative;
		z-index: 7; /* Всегда поверх всех фонов */
	}

	.hero__sticky-dynamic {
		position: relative;
		width: 100%;
		margin-top: 0px;
		display: flex;
		align-items: center;
		height: 380px;
	}

	.hero__cards {
		position: absolute;
		left: 0;
		right: 0;
		width: 100%;
		z-index: 2; /* Под оранжевым фоном */
	}

	.hero__services-wrapper {
		position: absolute;
		left: 0;
		right: 0;
		width: 100%;
		opacity: 0;
		pointer-events: none;
		transform: translateY(40px);
		z-index: 4; /* Поверх оранжевого фона, но под серым */
	}

	.hero__actions-wrapper {
		position: absolute;
		left: 0;
		right: 0;
		width: 100%;
		opacity: 0;
		pointer-events: none;
		transform: translateY(40px);
		z-index: 6; /* Поверх серого фона */
	}
}

@media (max-width: 768px) {
	.hero__sticky-wrapper {
		height: auto;
	}

	.hero__sticky-bg-orange {
		opacity: 1;
		transform: translateY(0);
	}

	.hero__sticky-bg-gray {
		display: none;
	}
	
	.hero__sticky-content {
		position: relative;
		height: auto;
		display: block;
		justify-content: normal;
		padding: 40px 0;
		z-index: 2;
	}
	
	.hero__ecosystem {
		margin-top: 80px;
	}

	.hero__sticky-dynamic {
		display: block;
		margin-top: 40px;
	}

	.hero__cards {
		position: relative;
		margin-top: 0;
	}

	.hero__services-wrapper {
		position: relative;
		margin-top: 80px;
		opacity: 1;
		pointer-events: auto;
		transform: none;
	}

	.hero__actions-wrapper {
		position: relative;
		margin-top: 80px;
		opacity: 1;
		pointer-events: auto;
		transform: none;
		background: linear-gradient(180deg, #adb0c1 50%, #ffffff 90%, #ffffff 100%);
		padding: 60px 0;
		margin-left: -20px;
		margin-right: -20px;
	}

	.hero__actions-wrapper .actions__inner,
	.hero__actions-wrapper .container {
		padding-left: 20px;
		padding-right: 20px;
	}
}

.hero__stats {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 30px;
	margin: 36px auto 0;
	max-width: 1000px;
	background-color: #ffffff;
	border: 1px solid #e1e3e6;
	border-radius: 30px;
	padding: 30px 40px;
	box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
}

.hero__stat {
	display: flex;
	flex-direction: column;
	gap: 12px;
	align-items: center;
	text-align: center;
}

.hero__stat-value {
	font-size: clamp(80px, 8vw, 120px);
	font-weight: 600;
	line-height: 0.82;
	transition: color 0.4s ease, -webkit-text-stroke 0.4s ease, text-stroke 0.4s ease;
}

.hero__stat-value--filled {
	color: #000000;
}

.hero__stat-value--outlined {
	color: transparent;
	-webkit-text-stroke: 1px #5f5f5f;
	text-stroke: 1px #5f5f5f;
}

.hero__stat-caption {
	font-size: clamp(18px, 1.8vw, 28px);
	font-weight: 400;
	line-height: 1;
	transition: color 0.4s ease;
}

.hero__stat-caption--filled {
	color: #000000;
}

.hero__stat-caption--outlined {
	color: #5f5f5f;
}

.hero__cards {
	margin-top: 60px;
}

@media (min-width: 769px) {
	.hero__cards-inner {
		display: flex;
		gap: 24px;
		overflow-x: scroll;
		padding-left: calc(50vw - 145px);
		padding-right: 100vw;
		padding-bottom: 20px;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}
}

@media (max-width: 768px) {
	.hero__cards {
		margin-top: 40px;
	}
	
	.hero__cards-inner {
		display: flex;
		gap: 16px;
		overflow-x: auto;
		padding-left: 20px;
		padding-right: 20px;
		padding-bottom: 20px;
		scrollbar-width: none;
		-ms-overflow-style: none;
	}
}

.hero__cards-inner::-webkit-scrollbar {
	display: none;
}

@media (max-width: 768px) {
	.hero__inner {
		padding-top: 160px;
	}

	.hero__title {
		margin-left: 0;
	}

	.hero__columns,
	.hero__stats {
		grid-template-columns: 1fr;
		margin-left: 0;
	}

	.hero__stats {
		padding: 30px 24px;
		gap: 30px;
	}
}

/* Services component integrated styles */
.services__inner {
	display: flex;
	gap: 10px;
	align-items: flex-start;
}

.services__left {
	flex: 0 0 35%;
	max-width: 480px;
	margin-left: 110px;
}

.services__title {
	font-family: var(--font-main);
	font-size: 2.3vw;
	font-weight: 500;
	line-height: 1;
	color: #000000;
	letter-spacing: -0.02em;
	margin-bottom: 24px;
}

.services__desc {
	font-family: var(--font-main);
	font-size: 16px;
	font-weight: 400;
	line-height: 1.4;
	color: rgba(0, 0, 0, 0.65);
	max-width: 320px;
}

.services__right {
	flex: 1;
}

:global(.services__table) {
	display: flex;
	flex-direction: column;
	width: 100%;
	border-top: 1px solid rgba(0, 0, 0, 0.15);
}

:global(.services__row) {
	display: flex;
	border-bottom: 1px solid rgba(0, 0, 0, 0.15);
}

:global(.services__col) {
	flex: 1;
	display: flex;
	align-items: baseline;
	gap: 12px;
	padding: 10px 10px;
	cursor: pointer;
	position: relative;
	background-color: transparent;
}

:global(.services__col::before) {
	content: "";
	position: absolute;
	left: -3%;
	top: -1px;
	width: 104%;
	height: calc(100% + 2px);
	background-color: var(--hover-bg, transparent);
	z-index: -1;
	transform: skewX(-23deg) scaleX(0);
	transform-origin: left;
	transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
}

:global(.services__col:hover::before) {
	transform: skewX(-23deg) scaleX(1);
}

:global(.services__col:first-child) {
	/* Сохраняем отступ справа, компенсируя новые padding */
	margin-right: 10px;
}

:global(.services__num) {
	font-family: var(--font-main);
	font-size: 13px;
	font-weight: 500;
	color: rgba(0, 0, 0, 0.4);
	font-feature-settings: "tnum";
	position: relative;
	top: -4px;
	transition: color 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	z-index: 1;
}

:global(.services__text) {
	font-family: var(--font-main);
	font-size: 1.5vw;
	font-weight: 500;
	color: #000000;
	transition: color 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	z-index: 1;
}

@media (max-width: 1024px) {
	.services__inner {
		gap: 40px;
	}
	.services__left {
		margin-left: 40px;
	}
}

@media (max-width: 768px) {
	.services__inner {
		flex-direction: column;
		gap: 48px;
	}

	.services__left {
		margin-left: 0;
		max-width: 100%;
	}

	:global(.services__row) {
		flex-direction: column;
	}

	:global(.services__col) {
		padding: 16px 0;
	}

	:global(.services__col:first-child) {
		padding-right: 0;
		border-bottom: 1px solid rgba(0, 0, 0, 0.08);
	}
}

/* Actions (Phase 3) integrated styles */
.actions__inner {
	display: flex;
	flex-direction: column;
	gap: 24px;
	width: 100%;
}

.actions__header {
	width: 100%;
	display: flex;
	flex-direction: column;
	align-items: flex-start;
	margin-top: 0px;
}

.actions__title {
	font-family: var(--font-main);
	font-size: 2.3vw;
	font-weight: 500;
	line-height: 1.1;
	color: #000000;
	letter-spacing: -0.02em;
	margin-bottom: 24px;
	text-align: left;
	margin-left: 110px;
}

@media (max-width: 1024px) {
	.actions__title {
		margin-left: 40px;
	}
}

@media (max-width: 768px) {
	.actions__title {
		margin-left: 0;
		text-align: left;
	}
}

.actions__desc {
	font-family: var(--font-main);
	font-size: 16px;
	font-weight: 400;
	line-height: 1.4;
	color: rgba(0, 0, 0, 0.65);
	text-align: center;
	width: 100%;
	margin-bottom: 20px;
}

.actions__desc-icon {
	display: inline-block;
	vertical-align: middle;
	margin-left: -30px;
	margin-right: 8px;
	width: 12px;
	height: 12px;
	color: #000000;
	position: relative;
	top: -1px;
}

@media (min-width: 1025px) {
	.actions__desc {
		padding-left: 200px;
		padding-right: 200px;
	}
}

@media (max-width: 1024px) {
	.actions__desc {
		padding-left: 40px;
		padding-right: 40px;
	}
}

.actions__content {
	width: 100%;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 24px;
	margin-left: 0;
	padding-right: 0;
}

.actions__btn {
	display: inline-flex;
	align-items: center;
	align-self: flex-start;
	margin-left: 110px;
	gap: 8px;
	background: transparent;
	border: none;
	padding: 0;
	padding-bottom: 4px;
	border-bottom: 1px solid #000000;
	color: #000000;
	font-family: var(--font-main);
	font-size: 16px;
	line-height: 1;
	font-weight: 500;
	cursor: pointer;
	transition: opacity 0.2s ease, border-color 0.2s ease;
}

@media (max-width: 1024px) {
	.actions__btn {
		margin-left: 40px;
	}
}

@media (max-width: 768px) {
	.actions__btn {
		margin-left: 0;
	}
}

.actions__btn:hover {
	opacity: 0.7;
}

.actions__btn-icon {
	transition: transform 0.2s ease;
}

.actions__btn:hover .actions__btn-icon {
	transform: translate(3px, -3px);
}

.actions__rows {
	display: flex;
	flex-direction: column;
	gap: 8px;
	width: 100%;
	align-items: flex-start;
	overflow: hidden;
}

.actions__row-pills {
	display: flex;
	flex-wrap: nowrap;
	width: max-content;
	will-change: transform;
}

.actions__row-pills:hover {
	animation-play-state: paused;
}

.actions__row-pills--1 {
	animation: marquee-left 120s linear infinite;
}

.actions__row-pills--2 {
	animation: marquee-right 150s linear infinite;
}


:global(.actions__pill) {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	padding: 15px 20px;
	border-radius: 9999px;
	border: 1px solid rgba(0, 0, 0, 0.2);
	background: transparent;
	color: #000000;
	font-family: var(--font-main);
	font-size: 15px;
	font-weight: 100;
	text-align: center;
	transition: all 0.2s ease;
	white-space: nowrap;
	margin-right: 12px;
}

@keyframes marquee-left {
	0% {
		transform: translateX(0);
	}
	100% {
		transform: translateX(-50%);
	}
}

@keyframes marquee-right {
	0% {
		transform: translateX(-50%);
	}
	100% {
		transform: translateX(0);
	}
}

@media (max-width: 1024px) {
	.actions__header {
		margin-top: 40px;
	}
}

@media (max-width: 768px) {
	.actions__header {
		margin-top: 0;
	}
	
	.actions__content {
		gap: 32px;
	}
	
	:global(.actions__pill) {
		font-size: 13px;
		padding: 6px 16px;
		margin-right: 8px;
	}
}

[typewriter="true"] .split-chars {
  opacity: 0.1;  /* изначально символы почти прозрачные */
}

.split-lines {
	display: inline;
}
.split-words {
	display: inline;
}
.split-chars {
	display: inline-block;
}
.split-space {
	display: inline-block;
}
</style>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// 1. Эффект печатной машинки для заголовка "Экосистема"
	const typewriterElement = document.querySelector('#ecosystem .hero__label[typewriter="true"]') as HTMLElement | null;
	if (typewriterElement) {
		const chars = typewriterElement.querySelectorAll('.split-chars');
		const delayAttr = typewriterElement.getAttribute('typewriter-delay');
		const delay = delayAttr ? parseInt(delayAttr, 10) / 1000 : 0.15;

		gsap.to(chars, {
			opacity: 1,
			duration: 0.002,
			stagger: {
				amount: 0.7,
			},
			delay: delay,
			scrollTrigger: {
				trigger: typewriterElement,
				start: 'top 90%', // Запускается, когда заголовок входит в область видимости
				toggleActions: 'play none none none',
			}
		});
	}

	// Sticky горизонтальный скролл и появление сервисов/услуг
	const stickyWrapper = document.getElementById('ecosystem') as HTMLElement | null;
	const cardsInner = document.querySelector('.hero__cards-inner') as HTMLElement | null;
	const bgOrange = document.querySelector('.hero__sticky-bg-orange') as HTMLElement | null;
	const bgGray = document.querySelector('.hero__sticky-bg-gray') as HTMLElement | null;
	const cardsBlock = document.querySelector('.hero__cards') as HTMLElement | null;
	const servicesWrapper = document.querySelector('.hero__services-wrapper') as HTMLElement | null;
	const actionsWrapper = document.querySelector('.hero__actions-wrapper') as HTMLElement | null;

	if (stickyWrapper && cardsInner && bgOrange && bgGray && cardsBlock && servicesWrapper && actionsWrapper) {
		const stickyContent = stickyWrapper.querySelector('.hero__sticky-content') as HTMLElement | null;
		const servicesLeft = document.querySelector('.services__left') as HTMLElement | null;
		const servicesRight = document.querySelector('.services__right') as HTMLElement | null;
		const actionsLeft = document.querySelector('.actions__header') as HTMLElement | null;
		const actionsPills = document.querySelector('.actions__rows') as HTMLElement | null;
		const actionsBtn = document.querySelector('.actions__btn') as HTMLElement | null;
		
		const statDivisionsValue = document.querySelector('#stat-divisions .hero__stat-value') as HTMLElement | null;
		const statDivisionsCaption = document.querySelector('#stat-divisions .hero__stat-caption') as HTMLElement | null;
		const statServicesValue = document.querySelector('#stat-services .hero__stat-value') as HTMLElement | null;
		const statServicesCaption = document.querySelector('#stat-services .hero__stat-caption') as HTMLElement | null;
		const statActionsValue = document.querySelector('#stat-actions .hero__stat-value') as HTMLElement | null;
		const statActionsCaption = document.querySelector('#stat-actions .hero__stat-caption') as HTMLElement | null;

		const updateStatsStyles = (phase: 1 | 2 | 3) => {
			if (!statDivisionsValue || !statDivisionsCaption || 
				!statServicesValue || !statServicesCaption ||
				!statActionsValue || !statActionsCaption) return;

			const elements = [
				{ value: statDivisionsValue, caption: statDivisionsCaption },
				{ value: statServicesValue, caption: statServicesCaption },
				{ value: statActionsValue, caption: statActionsCaption }
			];

			elements.forEach((el, index) => {
				const currentPhase = index + 1;
				if (currentPhase === phase) {
					el.value.classList.add('hero__stat-value--filled');
					el.value.classList.remove('hero__stat-value--outlined');
					el.caption.classList.add('hero__stat-caption--filled');
					el.caption.classList.remove('hero__stat-caption--outlined');
				} else {
					el.value.classList.remove('hero__stat-value--filled');
					el.value.classList.add('hero__stat-value--outlined');
					el.caption.classList.remove('hero__stat-caption--filled');
					el.caption.classList.add('hero__stat-caption--outlined');
				}
			});
		};

		const resetMobileStyles = () => {
			cardsBlock.style.removeProperty('opacity');
			cardsBlock.style.removeProperty('transform');
			servicesWrapper.style.removeProperty('opacity');
			servicesWrapper.style.removeProperty('transform');
			servicesWrapper.style.removeProperty('pointer-events');
			actionsWrapper.style.removeProperty('opacity');
			actionsWrapper.style.removeProperty('transform');
			actionsWrapper.style.removeProperty('pointer-events');
			bgOrange.style.removeProperty('transform');
			bgGray.style.removeProperty('transform');
			if (stickyContent) stickyContent.style.removeProperty('padding-top');
			if (servicesLeft) {
				servicesLeft.style.removeProperty('opacity');
				servicesLeft.style.removeProperty('transform');
			}
			if (servicesRight) {
				servicesRight.style.removeProperty('opacity');
				servicesRight.style.removeProperty('transform');
			}
			if (actionsLeft) {
				actionsLeft.style.removeProperty('opacity');
				actionsLeft.style.removeProperty('transform');
			}
			if (actionsPills) {
				actionsPills.style.removeProperty('opacity');
				actionsPills.style.removeProperty('transform');
			}
			if (actionsBtn) {
				actionsBtn.style.removeProperty('opacity');
				actionsBtn.style.removeProperty('transform');
			}
			stickyWrapper.style.removeProperty('height');
		};

		const handleScroll = () => {
			if (window.innerWidth <= 768) {
				resetMobileStyles();
				return;
			}

			const rect = stickyWrapper.getBoundingClientRect();
			const viewHeight = window.innerHeight;

			const scrolled = -rect.top;
			const maxHorizontalScroll = cardsInner.scrollWidth - cardsInner.clientWidth;
			const phase1Distance = maxHorizontalScroll * 1.8;
			const travelDistance = viewHeight - 150;
			const grayTravelDistance = viewHeight - 200;
			
			// Увеличиваем расстояние Phase 2 до 2.2 * viewHeight, чтобы задержать просмотр оранжевого блока
			const phase2Distance = viewHeight * 2.2;
			const phase3Distance = viewHeight * 2.5;
			const totalScrollDistance = phase1Distance + phase2Distance + phase3Distance;

			// Сдвиг старта скролла карточек на 400px до прилипания
			const scrollOffset = 400;

			// Анимация уменьшения верхнего отступа при прилипании
			if (stickyContent) {
				if (scrolled < 0) {
					stickyContent.style.paddingTop = '60px';
				} else {
					const paddingProgress = Math.min(1, scrolled / 150); // плавно переходит за 150px скролла
					const paddingTop = 60 - paddingProgress * 40; // от 60px до 20px
					stickyContent.style.paddingTop = `${paddingTop}px`;
				}
			}

			if (scrolled < -scrollOffset) {
				cardsInner.scrollLeft = 0;
				cardsBlock.style.opacity = '1';
				cardsBlock.style.transform = 'translateY(0)';
				servicesWrapper.style.opacity = '0';
				servicesWrapper.style.pointerEvents = 'none';
				servicesWrapper.style.transform = 'none';
				actionsWrapper.style.opacity = '0';
				actionsWrapper.style.pointerEvents = 'none';
				actionsWrapper.style.transform = 'translateY(40px)';
				bgOrange.style.transform = `translateY(${travelDistance}px)`;
				bgGray.style.transform = `translateY(${grayTravelDistance}px)`;
				updateStatsStyles(1);
				if (servicesLeft) {
					servicesLeft.style.opacity = '0';
					servicesLeft.style.transform = `translateY(${travelDistance}px)`;
				}
				if (servicesRight) {
					servicesRight.style.opacity = '0';
					servicesRight.style.transform = 'translateY(40px)';
				}
				if (actionsLeft) {
					actionsLeft.style.opacity = '0';
					actionsLeft.style.transform = `translateY(${grayTravelDistance}px)`;
				}
				if (actionsPills) {
					actionsPills.style.opacity = '0';
					actionsPills.style.transform = 'translateY(40px)';
				}
				if (actionsBtn) {
					actionsBtn.style.opacity = '0';
					actionsBtn.style.transform = 'translateY(40px)';
				}
				return;
			}

			if (scrolled > totalScrollDistance) {
				cardsInner.scrollLeft = maxHorizontalScroll;
				cardsBlock.style.opacity = '0';
				cardsBlock.style.transform = 'translateY(-40px)';
				servicesWrapper.style.opacity = '0';
				servicesWrapper.style.pointerEvents = 'none';
				actionsWrapper.style.opacity = '1';
				actionsWrapper.style.pointerEvents = 'auto';
				actionsWrapper.style.transform = 'translateY(0)';
				bgOrange.style.transform = 'translateY(0px)';
				bgGray.style.transform = 'translateY(0px)';
				updateStatsStyles(3);
				if (servicesLeft) {
					servicesLeft.style.opacity = '0';
					servicesLeft.style.transform = 'none';
				}
				if (servicesRight) {
					servicesRight.style.opacity = '0';
				}
				if (actionsLeft) {
					actionsLeft.style.opacity = '1';
					actionsLeft.style.transform = 'none';
				}
				if (actionsPills) {
					actionsPills.style.opacity = '1';
					actionsPills.style.transform = 'none';
				}
				if (actionsBtn) {
					actionsBtn.style.opacity = '1';
					actionsBtn.style.transform = 'none';
				}
				if (stickyContent) stickyContent.style.paddingTop = '20px';
				return;
			}

			// Фаза 1: Горизонтальная прокрутка карточек
			if (scrolled <= phase1Distance) {
				const progress1 = (scrolled + scrollOffset) / (phase1Distance + scrollOffset);
				cardsInner.scrollLeft = progress1 * maxHorizontalScroll;

				// Сброс фазы 2 и 3
				cardsBlock.style.opacity = '1';
				cardsBlock.style.transform = 'translateY(0)';
				servicesWrapper.style.opacity = '1';
				servicesWrapper.style.pointerEvents = 'none';
				servicesWrapper.style.transform = 'none';
				actionsWrapper.style.opacity = '0';
				actionsWrapper.style.pointerEvents = 'none';
				actionsWrapper.style.transform = 'translateY(40px)';
				bgGray.style.transform = `translateY(${grayTravelDistance}px)`;
				updateStatsStyles(1);

				// Оранжевый фон начинает подниматься за viewHeight * 0.75 до окончания горизонтального скролла (так же плавно, как и серый фон)
				const orangeRiseDistance = viewHeight * 0.75;
				const bgStart = phase1Distance - orangeRiseDistance;
				let bgTranslateY = travelDistance;
				let bgProgress = 0;
				if (scrolled > bgStart) {
					bgProgress = Math.min(1, (scrolled - bgStart) / orangeRiseDistance);
					bgTranslateY = travelDistance - bgProgress * travelDistance;
				}
				bgOrange.style.transform = `translateY(${bgTranslateY}px)`;

				if (servicesLeft) {
					servicesLeft.style.opacity = bgProgress > 0 ? '1' : '0';
					servicesLeft.style.transform = `translateY(${bgTranslateY}px)`;
				}
				if (servicesRight) {
					servicesRight.style.opacity = '0';
					servicesRight.style.transform = 'translateY(40px)';
				}
				if (actionsLeft) {
					actionsLeft.style.opacity = '0';
					actionsLeft.style.transform = `translateY(${grayTravelDistance}px)`;
				}
				if (actionsPills) {
					actionsPills.style.opacity = '0';
					actionsPills.style.transform = 'translateY(40px)';
				}
				if (actionsBtn) {
					actionsBtn.style.opacity = '0';
					actionsBtn.style.transform = 'translateY(40px)';
				}
			}
			// Фаза 2: Скрытие карточек, подъем оранжевого фона и появление сервисов
			else if (scrolled <= phase1Distance + phase2Distance) {
				cardsInner.scrollLeft = maxHorizontalScroll;
				bgGray.style.transform = `translateY(${grayTravelDistance}px)`;
				bgOrange.style.transform = 'translateY(0px)';
				actionsWrapper.style.opacity = '0';
				actionsWrapper.style.pointerEvents = 'none';
				actionsWrapper.style.transform = 'translateY(40px)';

				const progress2 = (scrolled - phase1Distance) / phase2Distance;

				// 1. Скрываем карточки (не используем opacity, чтобы они не исчезали плавно)
				// Добавляем translateX, чтобы они продолжали движение влево
				cardsBlock.style.opacity = '1';
				cardsBlock.style.transform = `translateY(${-progress2 * 40}px) translateX(${-progress2 * 500}px)`;

				// 3. Переключение активной цифры на 12
				updateStatsStyles(2);

				// 4. Появление услуг (сервисов)
				servicesWrapper.style.opacity = '1';
				servicesWrapper.style.transform = 'none';
				servicesWrapper.style.pointerEvents = progress2 > 0.6 ? 'auto' : 'none';

				if (servicesLeft && servicesRight) {
					// Левый блок остается полностью видимым (он поднялся с оранжевым фоном на фазе 1)
					servicesLeft.style.opacity = '1';
					servicesLeft.style.transform = 'none';

					// Правый блок с таблицей появляется на отрезке progress2 от 0.3 до 0.7 (после того как поднялся фон)
					const rightProgress = Math.max(0, Math.min(1, (progress2 - 0.3) / 0.4));
					servicesRight.style.opacity = rightProgress.toString();
					servicesRight.style.transform = `translateY(${(1 - rightProgress) * 40}px)`;
				}
				if (actionsLeft) {
					actionsLeft.style.opacity = '0';
					actionsLeft.style.transform = `translateY(${grayTravelDistance}px)`;
				}
				if (actionsPills) {
					actionsPills.style.opacity = '0';
					actionsPills.style.transform = 'translateY(40px)';
				}
				if (actionsBtn) {
					actionsBtn.style.opacity = '0';
					actionsBtn.style.transform = 'translateY(40px)';
				}
			}
			// Фаза 3: Скрытие сервисов, подъем серого фона и появление профильных услуг
			else {
				cardsInner.scrollLeft = maxHorizontalScroll;
				cardsBlock.style.opacity = '0';
				bgOrange.style.transform = 'translateY(0px)';

				const progress3 = (scrolled - phase1Distance - phase2Distance) / phase3Distance;

				// 1. УБРАНО скрытие контента Фазы 2 (убрана анимация opacity к 0).
				// Сервисы теперь остаются видимыми с полной непрозрачностью opacity = 1
				// и просто перекрываются поднимающимся снизу серым фоном.
				if (servicesLeft) servicesLeft.style.opacity = '1';
				if (servicesRight) servicesRight.style.opacity = '1';
				servicesWrapper.style.pointerEvents = progress3 > 0.3 ? 'none' : 'auto';

				// 2. Поднимаем серый фон (на отрезке progress3 от 0 до 0.35)
				const bgProgress = Math.min(1, progress3 / 0.35);
				const bgTranslateY = grayTravelDistance - bgProgress * grayTravelDistance;
				bgGray.style.transform = `translateY(${bgTranslateY}px)`;

				// 3. Переключение активной цифры на 70 (происходит после полного подъема серого фона, т.е. progress3 > 0.35)
				if (progress3 > 0.35) {
					updateStatsStyles(3);
				} else {
					updateStatsStyles(2);
				}

				// 4. Появление профильных услуг
				actionsWrapper.style.opacity = '1';
				actionsWrapper.style.transform = 'none';
				actionsWrapper.style.pointerEvents = progress3 > 0.75 ? 'auto' : 'none';

				// Левый блок (заголовок и подзаголовок) поднимается синхронно с серым фоном
				if (actionsLeft) {
					actionsLeft.style.opacity = bgProgress > 0 ? '1' : '0';
					actionsLeft.style.transform = `translateY(${bgTranslateY}px)`;
				}

				// Появление 2 рядов кнопок (от progress3 = 0.35 до 0.6)
				if (actionsPills) {
					const pillsProgress = Math.max(0, Math.min(1, (progress3 - 0.35) / 0.25));
					actionsPills.style.opacity = pillsProgress.toString();
					actionsPills.style.transform = `translateY(${(1 - pillsProgress) * 40}px)`;
				}

				// Появление кнопки Выбрать сервис (от progress3 = 0.55 до 0.75)
				if (actionsBtn) {
					const btnProgress = Math.max(0, Math.min(1, (progress3 - 0.55) / 0.2));
					actionsBtn.style.opacity = btnProgress.toString();
					actionsBtn.style.transform = `translateY(${(1 - btnProgress) * 40}px)`;
				}
			}
		};

		const updateWrapperHeight = () => {
			if (window.innerWidth > 768) {
				const maxHorizontalScroll = cardsInner.scrollWidth - cardsInner.clientWidth;
				const phase1Distance = maxHorizontalScroll * 1.8;
				const phase2Distance = window.innerHeight * 2.2;
				const phase3Distance = window.innerHeight * 2.5;
				// Высота = высота экрана + горизонтальный скролл + Фаза 2 + Фаза 3
				stickyWrapper.style.height = `${window.innerHeight + phase1Distance + phase2Distance + phase3Distance}px`;
			} else {
				stickyWrapper.style.removeProperty('height');
			}
		};

		const mediaQuery = window.matchMedia('(min-width: 769px)');
		let isScrollAttached = false;

		const initOrDestroyScroll = () => {
			if (mediaQuery.matches) {
				if (!isScrollAttached) {
					window.addEventListener('scroll', handleScroll);
					isScrollAttached = true;
				}
				updateWrapperHeight();
				handleScroll();
			} else {
				if (isScrollAttached) {
					window.removeEventListener('scroll', handleScroll);
					isScrollAttached = false;
				}
				resetMobileStyles();
			}
		};

		mediaQuery.addEventListener('change', initOrDestroyScroll);
		initOrDestroyScroll();

		window.addEventListener('resize', () => {
			if (mediaQuery.matches) {
				updateWrapperHeight();
				handleScroll();
			}
		});

		window.addEventListener('load', () => {
			initOrDestroyScroll();
		});

		window.addEventListener('astro:page-load', () => {
			initOrDestroyScroll();
		});

		setTimeout(() => {
			initOrDestroyScroll();
		}, 100);
	}

	// 3. Динамическая загрузка тегов-услуг из JSON
	const actionsRows = document.querySelector('.actions__rows') as HTMLElement | null;
	if (actionsRows) {
		const baseUrl = actionsRows.getAttribute('data-base-url') || '/';
		const row1 = actionsRows.querySelector('.actions__row-pills--1') as HTMLElement | null;
		const row2 = actionsRows.querySelector('.actions__row-pills--2') as HTMLElement | null;
		const row3 = actionsRows.querySelector('.actions__row-pills--3') as HTMLElement | null;
		const servicesTable = document.querySelector('.services__table') as HTMLElement | null;

		interface ServiceGroup {
			name: string;
			color: string;
			tags: string[];
		}

		interface TagItem {
			text: string;
			color: string;
		}

		fetch(`${baseUrl}Media/tags12.json`)
			.then(res => res.json())
			.then((data: ServiceGroup[]) => {
				// --- Заполнение таблицы сервисов (предыдущий блок) ---
				if (servicesTable) {
					servicesTable.innerHTML = '';
					
					// В JSON 12 элементов. В исходном дизайне первая колонка содержит элементы 1-6 (01-06),
					// а вторая колонка содержит элементы 7-12 (07-12).
					// Чтобы воссоздать строки корректно, первая колонка берется из первой половины массива,
					// а вторая колонка — из второй половины массива (смещение +6).
					const halfLength = Math.ceil(data.length / 2); // 6
					
					for (let i = 0; i < halfLength; i++) {
						const row = document.createElement('div');
						row.className = 'services__row';

						const leftGroup = data[i];
						const rightGroup = data[i + halfLength];

						const renderCol = (group: ServiceGroup | undefined, index: number) => {
							const col = document.createElement('div');
							col.className = 'services__col';
							if (!group) {
								col.style.visibility = 'hidden';
								return col;
							}

							col.setAttribute('data-hover-color', group.color);

							const numStr = (index + 1).toString().padStart(2, '0') + '/';
							col.innerHTML = `
								<span class="services__num">${numStr}</span>
								<span class="services__text">${group.name}</span>
							`;

							col.addEventListener('mouseenter', () => {
								const num = col.querySelector('.services__num') as HTMLElement;
								const text = col.querySelector('.services__text') as HTMLElement;
								
								col.style.setProperty('--hover-bg', group.color);
								
								if (num) num.style.color = '#ffffff';
								if (text) text.style.color = '#ffffff';
							});

							col.addEventListener('mouseleave', () => {
								const num = col.querySelector('.services__num') as HTMLElement;
								const text = col.querySelector('.services__text') as HTMLElement;
								
								if (num) num.style.color = 'rgba(0, 0, 0, 0.4)';
								if (text) text.style.color = '#000000';
							});

							return col;
						};

						row.appendChild(renderCol(leftGroup, i));
						row.appendChild(renderCol(rightGroup, i + halfLength));

						servicesTable.appendChild(row);
					}
				}

				// --- Заполнение бегущих строк с тегами ---
				// Извлекаем все теги со своими цветами
				let allTagItems: TagItem[] = [];
				data.forEach(group => {
					if (Array.isArray(group.tags)) {
						group.tags.forEach(tag => {
							allTagItems.push({
								text: tag,
								color: group.color || '#000000'
							});
						});
					}
				});

				const shuffle = (array: TagItem[]) => {
					const arr = [...array];
					for (let i = arr.length - 1; i > 0; i--) {
						const j = Math.floor(Math.random() * (i + 1));
						[arr[i], arr[j]] = [arr[j], arr[i]];
					}
					return arr;
				};

				const shuffledTags = shuffle(allTagItems);
				const half = Math.ceil(shuffledTags.length / 2);
				const tags1 = shuffledTags.slice(0, half);
				const tags2 = shuffledTags.slice(half);

				const renderPills = (container: HTMLElement | null, tags: TagItem[]) => {
					if (!container) return;
					// Генерируем HTML для тегов с data-hover-color
					const pillsHtml = tags.map(tag => 
						`<span class="actions__pill" data-hover-color="${tag.color}">${tag.text}</span>`
					).join('');
					
					container.innerHTML = pillsHtml + pillsHtml;

					// Добавляем обработчики hover для изменения цвета
					const pills = container.querySelectorAll('.actions__pill') as NodeListOf<HTMLElement>;
					pills.forEach(pill => {
						const hoverColor = pill.getAttribute('data-hover-color') || '#000000';
						pill.addEventListener('mouseenter', () => {
							pill.style.backgroundColor = hoverColor;
							pill.style.borderColor = hoverColor;
							pill.style.color = '#ffffff';
						});
						pill.addEventListener('mouseleave', () => {
							pill.style.backgroundColor = 'transparent';
							pill.style.borderColor = 'rgba(0, 0, 0, 0.2)';
							pill.style.color = '#000000';
						});
					});
				};

				renderPills(row1, tags1);
				renderPills(row2, tags2);
			})
			.catch(err => console.error('Error loading tags:', err));
	}
</script>
