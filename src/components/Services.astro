					</div>
					<div class="services__col">
						<span class="services__num">08/</span>
						<span class="services__text">Design</span>
					</div>
				</div>

				<div class="services__row">
					<div class="services__col">
						<span class="services__num">03/</span>
						<span class="services__text">Due diligence</span>
					</div>
					<div class="services__col">
						<span class="services__num">09/</span>
						<span class="services__text">Web & App Dev</span>
					</div>
				</div>

				<div class="services__row">
					<div class="services__col">
						<span class="services__num">04/</span>
						<span class="services__text">PR</span>
					</div>
					<div class="services__col">
						<span class="services__num">10/</span>
						<span class="services__text">Tech</span>
					</div>
				</div>

				<div class="services__row">
					<div class="services__col">
						<span class="services__num">05/</span>
