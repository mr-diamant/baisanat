---
export interface Props {
  en: string;
  ru: string;
  items: string;
  logo: string;
  theme?: string;
}

const { en, ru, items, logo, theme } = Astro.props;
---

<article class={`hero-card hero-card--${theme}`}>
	<div class="hero-card__top">
		<img class="hero-card__logo" src={logo} alt={en} width="280" height="28" loading="lazy" />
		<p class="hero-card__en">{en}</p>
	</div>
	<div class="hero-card__body">
		<h3 class="hero-card__title">{ru}</h3>
		<span class="hero-card__line"></span>
		<p class="hero-card__items">{items}</p>
	</div>
</article>

<style>
.hero-card {
	position: relative;
	border: none;
	border-radius: 0;
	padding: clamp(32px, 3vw, 44px) clamp(28px, 2.5vw, 36px);
	min-height: clamp(360px, 27vw, 470px);
	display: flex;
	flex-direction: column;
	justify-content: flex-end;
	color: var(--color-white);
	backdrop-filter: blur(6px);
	overflow: hidden;
	clip-path: polygon(0 0, calc(100% - 36px) 0, 100% 36px, 100% 100%, 0 100%);
	flex: 0 0 clamp(270px, 19vw, 340px);
}

.hero-card::before {
	content: '';
	position: absolute;
	inset: 0;
	background: linear-gradient(180deg, rgba(255,255,255,0.06) 0%, rgba(255,255,255,0) 60%);
	pointer-events: none;
}

.hero-card__top {
	position: relative;
	z-index: 1;
}

.hero-card__logo {
	width: 100%;
	height: auto;
	object-fit: contain;
	object-position: left center;
	margin-bottom: 6px;
}

.hero-card__en {
	font-size: 1.6vw;
	font-weight: 300;
}

.hero-card__body {
	position: relative;
	z-index: 1;
	margin-top: 28px;
}

.hero-card__title {
	font-size: clamp(20px, 1.8vw, 32px);
	font-weight: 600;
	line-height: 1.2;
	margin-bottom: 12px;
}

.hero-card__line {
	display: block;
	width: 50px;
	height: 1px;
	background: var(--color-white);
	margin-bottom: 12px;
}

.hero-card__items {
	font-size: clamp(14px, 1.3vw, 22px);
	font-weight: 400;
	line-height: 1;
	opacity: 0.85;
	white-space: pre-line;
}

.hero-card--expert {
	background: linear-gradient(45deg, #15162a 0%, #284ea4 100%);
}

.hero-card--communications {
	background: linear-gradient(45deg, #20091d 0%, #812f8b 100%);
}

.hero-card--media {
	background: linear-gradient(45deg, #09190f 0%, #049280 100%);
}

.hero-card--events {
	background: linear-gradient(45deg, #701f0d 0%, #f16d26 100%);
}

.hero-card--academy {
	background: linear-gradient(45deg, #2d0b0a 0%, #9a163b 100%);
}

@media (max-width: 768px) {
	.hero-card {
		min-height: auto;
		padding: 28px 24px;
		flex: 0 0 240px;
	}
}
</style>
