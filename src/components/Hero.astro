---
import HeroCard from './HeroCard.astro';
---

<section class="hero">
	<div class="container hero__inner">
		<div class="hero__content">
			<h1 class="hero__title">
				<span class="hero__title-accent">Центр экспертизы<br />и проектных решений</span>
				<span class="hero__title-base">
					в медиа, коммуникациях<br />и креативных индустриях
				</span>
			</h1>
		</div>

		<div class="hero__formula">
			<div class="hero__section-label">
				<span class="hero__number">01</span>
				<div class="hero__label-block">
					<span class="hero__label">Формула Baisanat</span>
					<span class="hero__line"></span>
				</div>
			</div>

			<div class="hero__columns">
				<p>Исследуем рынки,<br />выявляем тренды</p>
				<p>Определяем стратегии,<br />выстраиваем процессы</p>
				<p>Воплощаем идеи,<br />контролируем результат</p>
			</div>
		</div>

		<div class="hero__ecosystem">
			<div class="hero__section-label hero__section-label--dark">
				<span class="hero__number">02</span>
				<div class="hero__label-block">
					<span class="hero__label">Экосистема</span>
					<span class="hero__line hero__line--dark"></span>
				</div>
			</div>

			<div class="hero__stats">
				<div class="hero__stat">
					<span class="hero__stat-value hero__stat-value--filled">5</span>
					<span class="hero__stat-caption hero__stat-caption--filled">подразделений</span>
				</div>
				<div class="hero__stat">
					<span class="hero__stat-value hero__stat-value--outlined">12</span>
					<span class="hero__stat-caption hero__stat-caption--outlined">сервисов</span>
				</div>
				<div class="hero__stat">
					<span class="hero__stat-value hero__stat-value--outlined">70</span>
					<span class="hero__stat-caption hero__stat-caption--outlined">услуг</span>
				</div>
			</div>
		</div>
	</div>

	<!-- Bottom cards are part of the full design but outside the first visible viewport for now -->
	<div class="hero__cards">
		<div class="container hero__cards-inner">
			<HeroCard
				en="Expert"
				ru="Управление"
				items="Reserch /PMO /Due diligence"
				logo={import.meta.env.BASE_URL + 'logo1.png'}
			/>
			<HeroCard
				en="Communications"
				ru="Продвижение"
				items="PR /Marketing /Buying"
				logo={import.meta.env.BASE_URL + 'logo2.png'}
			/>
			<HeroCard
				en="Media"
				ru="Креатив"
				items="Media Production /Design /Web & App"
				logo={import.meta.env.BASE_URL + 'logo3.png'}
			/>
			<HeroCard
				en="Events"
				ru="События"
				items="Technical solutions /Event"
				logo={import.meta.env.BASE_URL + 'logo4.png'}
			/>
		</div>
	</div>
</section>

<style>
.hero {
	position: relative;
	min-height: 1180px;
	background:
		linear-gradient(
			180deg,
			#07070f 0%,
			#0e143f 22%,
			#1e2b86 48%,
			#2b3fa3 72%,
			#4154b8 100%
		);
	overflow: hidden;
	padding-bottom: 80px;
}

.hero__inner {
	position: relative;
	z-index: 1;
	padding-top: 240px;
}

.hero__title {
	font-size: clamp(42px, 5.5vw, 72px);
	font-weight: 400;
	line-height: 1.03;
	letter-spacing: -0.02em;
	max-width: 1100px;
}

.hero__title-accent {
	display: block;
	color: #8ea4e0;
	font-weight: 500;
}

.hero__title-base {
	display: block;
	color: var(--color-white);
	margin-top: 0.1em;
}

.hero__formula {
	margin-top: 160px;
}

.hero__section-label {
	display: flex;
	align-items: flex-start;
	gap: 80px;
	color: var(--color-white);
}

.hero__section-label--dark {
	color: #ffffff;
}

.hero__number {
	font-size: 14px;
	font-weight: 400;
	line-height: 1;
	opacity: 0.8;
	min-width: 30px;
	padding-top: 4px;
}

.hero__label-block {
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.hero__label {
	font-size: 18px;
	font-weight: 400;
	line-height: 1;
}

.hero__line {
	display: block;
	width: 50px;
	height: 1px;
	background: var(--color-accent);
}

.hero__line--dark {
	background: rgba(255, 255, 255, 0.5);
}

.hero__columns {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 40px;
	margin-top: 36px;
	margin-left: 110px;
	max-width: 1200px;
}

.hero__columns p {
	font-size: clamp(22px, 2.2vw, 34px);
	font-weight: 400;
	line-height: 1.1;
	color: var(--color-white);
}

.hero__ecosystem {
	margin-top: 120px;
}

.hero__stats {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 40px;
	margin-top: 36px;
	margin-left: 110px;
	max-width: 1200px;
}

.hero__stat {
	display: flex;
	flex-direction: column;
	gap: 8px;
}

.hero__stat-value {
	font-size: clamp(120px, 14vw, 200px);
	font-weight: 600;
	line-height: 0.82;
}

.hero__stat-value--filled {
	color: #ffffff;
}

.hero__stat-value--outlined {
	color: transparent;
	-webkit-text-stroke: 2px rgba(255, 255, 255, 0.55);
	text-stroke: 2px rgba(255, 255, 255, 0.55);
}

.hero__stat-caption {
	font-size: clamp(22px, 2.2vw, 34px);
	font-weight: 400;
	line-height: 1;
}

.hero__stat-caption--filled {
	color: #ffffff;
}

.hero__stat-caption--outlined {
	color: rgba(255, 255, 255, 0.55);
}

.hero__cards {
	margin-top: 80px;
}

.hero__cards-inner {
	display: grid;
	grid-template-columns: repeat(4, 1fr);
	gap: 24px;
}

@media (max-width: 1200px) {
	.hero__cards-inner {
		grid-template-columns: repeat(2, 1fr);
	}
}

@media (max-width: 768px) {
	.hero__inner {
		padding-top: 160px;
	}

	.hero__columns,
	.hero__stats {
		grid-template-columns: 1fr;
		margin-left: 0;
	}

	.hero__cards-inner {
		grid-template-columns: 1fr;
	}
}
</style>
