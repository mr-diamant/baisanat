---
---

<section class="hero">
	<div class="hero__bg">
		<video class="hero__video" autoplay loop muted playsinline aria-hidden="true">
			<source src={import.meta.env.BASE_URL + 'Media/blur-transcode.webm'} type="video/webm" />
			<source src={import.meta.env.BASE_URL + 'Media/blur-transcode.mp4'} type="video/mp4" />
		</video>
		<div class="hero__video-overlay"></div>
	</div>

	<div class="container hero__inner">
		<div class="hero__content">
			<h1 class="hero__title">
				<span class="hero__title-accent">Центр экспертизы<br />и проектных решений</span>
				<span class="hero__title-base">
					в медиа, коммуникациях<br />и креативных индустриях
				</span>
			</h1>
		</div>

		<div class="hero__formula">
			<div class="hero__section-label">
				<span class="hero__number">01</span>
				<div class="hero__label-block">
					<span class="hero__label" typewriter="true" typewriter-delay="150">
						<span class="split-lines">
							<span class="split-words">
								<span class="split-chars">Ф</span>
								<span class="split-chars">о</span>
								<span class="split-chars">р</span>
								<span class="split-chars">м</span>
								<span class="split-chars">у</span>
								<span class="split-chars">л</span>
								<span class="split-chars">а</span>
								<span class="split-space">&nbsp;</span>
								<span class="split-chars">B</span>
								<span class="split-chars">a</span>
								<span class="split-chars">i</span>
								<span class="split-chars">s</span>
								<span class="split-chars">a</span>
								<span class="split-chars">n</span>
								<span class="split-chars">a</span>
								<span class="split-chars">t</span>
							</span>
						</span>
					</span>
					<span class="hero__line"></span>
				</div>
			</div>

			<div class="hero__columns">
				<p>Исследуем рынки,<br />выявляем тренды</p>
				<p>Определяем стратегии,<br />выстраиваем процессы</p>
				<p>Воплощаем идеи,<br />контролируем результат</p>
			</div>
		</div>
	</div>
</section>

<style>
.hero {
	position: relative;
	z-index: 1;
	min-height: 100vh;
	padding-bottom: 140px;
}

@media (max-width: 768px) {
	.hero {
		overflow: hidden;
		padding-bottom: 80px;
	}
}

.hero__bg {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
	background-color: #ffffff;
	z-index: -1;
	overflow: hidden;
}

.hero__video {
	position: absolute;
	top: -250px; /* подняли на 200px + 50px запас на размытие краев */
	left: -5%;
	width: 110%;
	height: calc(100% + 250px);
	object-fit: cover;
	pointer-events: none;
	z-index: 0;
	filter: blur(65px);
	transform: scale(1.06); /* компенсирует полупрозрачные края от размытия */
}

.hero__video-overlay {
	position: absolute;
	inset: 0;
	background: linear-gradient(180deg, transparent 40%, #ffffff 100%);
	pointer-events: none;
	z-index: 1;
}

@media (max-width: 768px) {
	.hero__video {
		top: -150px;
		height: calc(100% + 150px);
		filter: blur(40px);
	}
	.hero__video-overlay {
		background: linear-gradient(180deg, transparent 40%, #ffffff 100%);
	}
}


.hero__inner {
	position: relative;
	z-index: 1;
	padding-top: 240px;
}

.hero__title {
	font-size: clamp(34px, 4.5vw, 60px);
	font-weight: 700;
	line-height: 1.03;
	letter-spacing: -0.02em;
	max-width: 1100px;
	margin-left: 110px;
}

.hero__title-accent {
	display: block;
	color: #85a0ff;
	font-weight: 700;
}

.hero__title-base {
	display: block;
	color: var(--color-white);
	margin-top: 0.1em;
}

.hero__formula {
	margin-top: 160px;
}

.hero__section-label {
	display: flex;
	align-items: flex-start;
	gap: 80px;
	color: var(--color-white);
}

.hero__section-label--dark {
	color: #000000;
}

.hero__number {
	font-size: 12px;
	font-weight: 400;
	line-height: 1;
	opacity: 0.8;
	min-width: 30px;
	padding-top: 4px;
}

.hero__label-block {
	display: flex;
	flex-direction: column;
	gap: 12px;
}

.hero__label {
	font-size: 15px;
	font-weight: 400;
	line-height: 1;
}

.hero__line {
	display: block;
	width: 50px;
	height: 1px;
	background: var(--color-accent);
}

.hero__line--dark {
	background: #000000;
}

.hero__columns {
	display: grid;
	grid-template-columns: repeat(3, 1fr);
	gap: 40px;
	margin-top: 36px;
	margin-left: 110px;
	max-width: 1200px;
}

.hero__columns p {
	font-size: clamp(18px, 1.8vw, 28px);
	font-weight: 400;
	line-height: 1.1;
	color: var(--color-white);
}

@media (max-width: 768px) {
	.hero__inner {
		padding-top: 160px;
	}

	.hero__title {
		margin-left: 0;
	}

	.hero__columns {
		grid-template-columns: 1fr;
		margin-left: 0;
	}
}

[typewriter="true"] .split-chars {
  opacity: 0.1;  /* изначально символы почти прозрачные */
}

.split-lines {
	display: inline;
}
.split-words {
	display: inline;
}
.split-chars {
	display: inline-block;
}
.split-space {
	display: inline-block;
}
</style>

<script>
	import { gsap } from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	// 1. Эффект печатной машинки для заголовка "Формула Baisanat"
	const typewriterElement = document.querySelector('.hero__label[typewriter="true"]') as HTMLElement | null;
	if (typewriterElement) {
		const chars = typewriterElement.querySelectorAll('.split-chars');
		const delayAttr = typewriterElement.getAttribute('typewriter-delay');
		const delay = delayAttr ? parseInt(delayAttr, 10) / 1000 : 0.15;

		gsap.to(chars, {
			opacity: 1,
			duration: 0.002,
			stagger: {
				amount: 0.7,
			},
			delay: delay,
			scrollTrigger: {
				trigger: typewriterElement,
				start: 'top 90%', // Запускается, когда заголовок входит в область видимости
				toggleActions: 'play none none none',
			}
		});
	}

	// 2. Поочередное появление трех колонок с текстом
	const columns = document.querySelector('.hero__columns') as HTMLElement | null;
	if (columns) {
		const paragraphs = columns.querySelectorAll('p');
		gsap.from(paragraphs, {
			opacity: 0,
			y: 30,
			duration: 0.8,
			stagger: 0.25,
			ease: 'power2.out',
			scrollTrigger: {
				trigger: columns,
				start: 'top 85%',
				toggleActions: 'play none none none'
			}
		});
	}
</script>
