---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/png" href={import.meta.env.BASE_URL + 'Media/favicon.png'} />
		<meta name="viewport" content="width=1440" />
		<meta name="generator" content={Astro.generator} />
		<title>Контакты — Baisanat Holding</title>
		<meta name="description" content="Контакты и адрес компании Baisanat Holding в Алматы" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
	</head>
	<body class="dark-body">
		<Header theme="dark" />
		
		<main class="contacts-page">
			<div class="container">
				<!-- Заголовок с номером блока как на главной -->
				<div class="hero__section-label projects__label">
					<span class="hero__number">05</span>
					<div class="hero__label-block">
						<span class="hero__label" typewriter="true" typewriter-delay="150">
							<span class="split-lines">
								<span class="split-words">
									<span class="split-chars">К</span><span class="split-chars">о</span><span class="split-chars">н</span><span class="split-chars">т</span><span class="split-chars">а</span><span class="split-chars">к</span><span class="split-chars">т</span><span class="split-chars">ы</span>
								</span>
							</span>
						</span>
						<span class="hero__line"></span>
					</div>
				</div>

				<div class="contacts-content">
					<div class="contacts-grid">
						<!-- Левая колонка с информацией -->
						<div class="contacts-info">
							<h1 class="contacts-title">Свяжитесь<br />с нами</h1>
							
							<div class="contacts-blocks">
								<div class="contacts-block">
									<span class="contacts-block__label">Adress</span>
									<p class="contacts-block__value">
										65 Nauryzbay Batyr St.,<br />
										Office 412<br />
										Almaty, Kazakhstan
									</p>
								</div>

								<div class="contacts-block">
									<span class="contacts-block__label">Email</span>
									<a href="mailto:info@bh.kz" class="contacts-block__value contacts-email">info@bh.kz</a>
								</div>

								<div class="contacts-block">
									<span class="contacts-block__label">Socials</span>
									<div class="contacts-socials-grid">
										<div class="contacts-social-col">
											<a href="#" class="contacts-social-link">Linkedin</a>
											<a href="#" class="contacts-social-link">Instagram</a>
										</div>
										<div class="contacts-social-col">
											<a href="#" class="contacts-social-link">Facebook</a>
											<a href="#" class="contacts-social-link">Telegram</a>
										</div>
									</div>
								</div>
							</div>
						</div>

						<!-- Правая колонка с картой -->
						<div class="contacts-map">
							<div class="contacts-map-card">
								<iframe 
									src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2906.568461747805!2d76.9312389!3d43.2599723!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x38836eb7847c2317%3A0xe214ff94e019fb4a!2z0YPQuy4g0J3QsNGD0YDRi9C30LHQsNC5INCR0LDRgtGL0YDQsCA2NSwg0JDQu9C80LDRgtGLIDA1MDAwMA!5e0!3m2!1sru!2skz!4v1700000000000!5m2!1sru!2skz" 
									width="100%" 
									height="100%" 
									style="border:0;" 
									allowfullscreen="" 
									loading="lazy" 
									referrerpolicy="no-referrer-when-downgrade">
								</iframe>
							</div>
						</div>
					</div>
				</div>
			</div>
		</main>

		<Footer theme="dark" />

		<script>
			import Lenis from 'lenis';
			import { gsap } from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';

			gsap.registerPlugin(ScrollTrigger);

			const lenis = new Lenis({
				duration: 1.8,
				easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
				autoRaf: true,
				smoothWheel: true,
			});

			lenis.on('scroll', ScrollTrigger.update);

			// Эффект печатной машинки для "Контакты"
			const typewriterElement = document.querySelector('.hero__label[typewriter="true"]') as HTMLElement | null;
			if (typewriterElement) {
				const chars = typewriterElement.querySelectorAll('.split-chars');
				const delayAttr = typewriterElement.getAttribute('typewriter-delay');
				const delay = delayAttr ? parseInt(delayAttr, 10) / 1000 : 0.15;

				gsap.to(chars, {
					opacity: 1,
					duration: 0.002,
					stagger: {
						amount: 0.5,
					},
					delay: delay,
					scrollTrigger: {
						trigger: typewriterElement,
						start: 'top 95%',
						toggleActions: 'play none none none',
					}
				});
			}
		</script>
	</body>
</html>

<style>
	.dark-body {
		background: linear-gradient(#344FD5, #0d1478 40%) !important;
		color: var(--color-white) !important;
	}

	.contacts-page {
		padding-top: 160px;
		padding-bottom: 120px;
	}

	.hero__section-label {
		position: relative;
		color: var(--color-white);
	}
	.projects__label {
		margin-bottom: 60px;
	}
	.hero__number {
		position: absolute;
		left: -80px;
		top: 4px;
		font-size: 12px;
		font-weight: 400;
		line-height: 1;
		opacity: 0.8;
		min-width: 30px;
	}
	.hero__label-block {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.hero__label {
		font-size: 15px;
		font-weight: 400;
		line-height: 1;
	}
	.hero__line {
		display: block;
		width: 50px;
		height: 1px;
		background: var(--color-accent);
	}

	.contacts-content {
	}

	.contacts-grid {
		display: grid;
		grid-template-columns: 2fr 3fr;
		gap: 1vw;
		align-items: start;
	}

	.contacts-title {
		font-family: var(--font-main);
		font-size: clamp(32px, 4vw, 67px);
		font-weight: 500;
		line-height: 1;
		color: var(--color-white);
		margin-bottom: 2vw;
		max-width: 1100px;
	}

	.contacts-blocks {
		display: flex;
		flex-direction: column;
		gap: 36px;
	}

	.contacts-block {
		display: flex;
		flex-direction: column;
		gap: 0.7vw;
	}
	.contacts-block:last-child {
		margin-top: 3.5vw;
	}

	.contacts-block__label {
		font-size: 1vw;
		font-weight: 400;
		text-transform: capitalize;
		color: rgba(255, 255, 255, 0.4);
		letter-spacing: 0;
	}

	.contacts-block__value {
		font-size: 1.3vw;
		line-height: 1;
		color: var(--color-white);
		font-weight: 400;
	}

	.contacts-email {
		font-size: 1.3vw;
		color: var(--color-white);
		text-decoration: none;
		transition: color 0.2s ease;
		display: inline-block;
		width: fit-content;
	}

	.contacts-email:hover {
		color: var(--color-accent);
	}

	.contacts-socials-grid {
		display: flex;
		gap: 3.5vw;
	}

	.contacts-social-col {
		display: flex;
		flex-direction: column;
		gap: 13px;
	}

	.contacts-social-link {
		font-size: 1.3vw;
		color: var(--color-white);
		transition: color 0.2s ease;
	}

	.contacts-social-link:hover {
		color: var(--color-accent);
	}

	.contacts-map-card {
		width: 100%;
		height: 32vw;
		border-radius: 20px;
		overflow: hidden;
		background: #111430;
		border: 1px solid rgba(255, 255, 255, 0.1);
	}

	.contacts-map-card iframe {
		width: 100%;
		height: 100%;
		filter: grayscale(1) invert(0.9) contrast(1.1) brightness(0.9);
	}

	[typewriter="true"] .split-chars {
		opacity: 0.1;
	}
	.split-lines {
		display: inline;
	}
	.split-words {
		display: inline;
	}
	.split-chars {
		display: inline-block;
	}

	@media (max-width: 1024px) {
		.contacts-grid {
			gap: 40px;
		}
	}

	@media (max-width: 768px) {
		.contacts-page {
			padding-top: 120px;
			padding-bottom: 80px;
		}


		.contacts-grid {
			grid-template-columns: 1fr;
			gap: 48px;
		}

		.contacts-map-card {
			height: 350px;
		}
		.contacts-title {
			font-size: 32px;
			margin-bottom: 24px;
		}
		.contacts-block__label {
			font-size: 13px;
		}
		.contacts-block__value {
			font-size: 16px;
			line-height: 1.5;
		}
		.contacts-social-link {
			font-size: 16px;
		}
		.contacts-email {
			font-size: 20px;
		}
		.contacts-block:last-child {
			margin-top: 24px;
		}
	}

	@media (min-width: 1728px) {
		.contacts-page {
			padding-top: 18.7vw;
		}
		.projects__label {
			margin-bottom: 4.5vw;
		}
	}
</style>
